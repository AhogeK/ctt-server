# Environment Variables for Local Development
# Copy this file to .env and customize for your environment
# WARNING: Never commit .env to Git (it's in .gitignore)

# PostgreSQL Configuration
POSTGRES_DB=ctt_server
POSTGRES_USER=ctt
POSTGRES_PASSWORD=your_local_password
POSTGRES_EXTERNAL_PORT=15432

# Redis Configuration
REDIS_PASSWORD=your_redis_password
REDIS_EXTERNAL_PORT=16379

# Database Connection (for application-local.yaml)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ctt_server
DB_USERNAME=postgres
DB_PASSWORD=your_local_password

# Redis Connection (for application-local.yaml)
REDIS_HOST=localhost
REDIS_PORT=6379

# Mailpit SMTP (Local Development)
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=1025
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=

# Mailpit External Ports (Docker Compose)
MAIL_SMTP_EXTERNAL_PORT=1025
MAIL_UI_EXTERNAL_PORT=8025

# App Server Ports (Docker Compose)
APP_PORT=8080
APP_EXTERNAL_PORT=8004

# Resend SMTP API Key (Production)
RESEND_API_KEY=re_xxx

# Mail Sender Configuration
MAIL_FROM_ADDRESS=noreply@localhost
MAIL_FROM_NAME=CTT Server

# JWT Secret Key (256+ bits recommended)
JWT_SECRET_KEY=your_jwt_secret_key_must_be_at_least_256_bits

# Frontend Base URL (for email verification links)
FRONTEND_BASE_URL=http://localhost:5173

# Spring Profile
SPRING_PROFILES_ACTIVE=local

# GitHub OAuth (for social login)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

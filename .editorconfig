root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{java,kt,kts}]
indent_size = 4

[*.{xml,yaml,yml,json}]
indent_size = 2

[*.{md,txt}]
max_line_length = off

[Makefile]
indent_style = tab
